<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Background -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#66BB6A"
                android:endColor="#4CAF50"
                android:angle="135"/>
        </shape>
    </item>
    
    <!-- Brain/Mind Symbol -->
    <item android:gravity="center">
        <layer-list>
            <!-- Outer Circle -->
            <item>
                <shape android:shape="oval">
                    <size android:width="140dp" android:height="140dp"/>
                    <stroke android:width="4dp" android:color="#FFFFFF" android:alpha="0.9"/>
                </shape>
            </item>
            
            <!-- Brain Curves - Top -->
            <item android:top="25dp">
                <shape android:shape="rectangle">
                    <corners android:radius="40dp"/>
                    <size android:width="80dp" android:height="4dp"/>
                    <solid android:color="#FFFFFF"/>
                </shape>
            </item>
        </layer-list>
    </item>
</layer-list>
